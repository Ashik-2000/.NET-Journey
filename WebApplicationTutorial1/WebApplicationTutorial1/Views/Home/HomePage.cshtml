<!DOCTYPE html>
<html>
<head>
    <title>Gym Regitration Form</title>
    <link href="~/Style.css" rel="stylesheet" />
</head>
<body>
    <div class="registration-page">
        <div class="registration-card">
            <div class="form-header">
                <h1>Gym Membership Registration</h1>
                <p>Please fill in your profile information.</p>
            </div>

            <form>
                <div class="form-grid">

                    <div class="form-group full-width">
                        <label>Name<span class="required">*</span></label>
                        <input type="text" placeholder="Enter full name">
                    </div>

                    <div class="form-group">
                        <label>Email Address<span class="required">*</span></label>
                        <input type="email" placeholder="Enter email">
                    </div>

                    <div class="form-group">
                        <label>Phone Number<span class="required">*</span></label>
                        <input type="tel" placeholder="Enter phone number">
                    </div>

                    <div class="form-group">
                        <label>Date of Birth<span class="required">*</span></label>
                        <input type="date">
                    </div>

                    <div class="form-group">
                        <label>Gender<span class="required">*</span></label>
                        <select>
                            <option>Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Height (ft)<span class="required">*</span></label>
                        <input type="number" step="0.01" placeholder="e.g: 5.8">
                    </div>

                    <div class="form-group">
                        <label>Weight (kg)<span class="required">*</span></label>
                        <input type="number" step="0.1" placeholder="e.g: 70">
                    </div>

                    <div class="form-group">
                        <label>Emergency Contact Name</label>
                        <input type="text" placeholder="Emergency contact">
                    </div>

                    <div class="form-group">
                        <label>Emergency Contact Number</label>
                        <input type="tel" placeholder="Contact number">
                    </div>

                    <div class="form-group">
                        <label>Division<span class="required">*</span></label>
                        <select>
                            <option>Select Division</option>
                            <option>Dhaka</option>
                            <option>Chattogram</option>
                            <option>Rajshahi</option>
                            <option>Khulna</option>
                            <option>Barishal</option>
                            <option>Sylhet</option>
                            <option>Rangpur</option>
                            <option>Mymensingh</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>City<span class="required">*</span></label>
                        <input type="text" placeholder="Enter city">
                    </div>
                    <div class="form-group full-width">
                        <label>Address</label>
                        <textarea rows="3" placeholder="House/Road, Block, Apartment, etc."></textarea>
                    </div>

                    <div class="form-group">
                        <label>Fitness Goal<span class="required">*</span></label>
                        <select>
                            <option>Select Goal</option>
                            <option>Weight Loss</option>
                            <option>Muscle Gain</option>
                            <option>General Fitness</option>
                            <option>Strength Training</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Membership Plan<span class="required">*</span></label>
                        <select>
                            <option>Select Plan</option>
                            <option>Monthly</option>
                            <option>Quarterly</option>
                            <option>Yearly</option>
                        </select>
                    </div>

                    <div class="form-group full-width">
                        <label>Medical Notes (Optional)</label>
                        <textarea rows="3" placeholder="Any medical conditions or notes"></textarea>
                    </div>

                </div>

                <div class="button-section">
                    <button type="submit">Register Member</button>
                </div>
            </form>
        </div>
    </div>
    </body>
</html>