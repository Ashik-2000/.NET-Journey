@using WebApplicationTutorial1.Models
@{
    var title = "This is title";
    var profile = new Profile(){Name = "Ashik", Age=26, City = "Dhaka"};
}
<!DOCTYPE html>
<html>
<head>
    <title>@title</title>
    <link href="~/Style.css" rel="stylesheet" />
</head>
<body>
    <div class="registration-page">
        <div class="registration-card">
            <div class="form-header">
                <h1>Gym Membership Registration</h1>
                <p>Please fill in your profile information.</p>
            </div>

            <form>
                <div class="form-grid">

                    <div class="form-group">
                        <label>First Name</label>
                        <input type="text" placeholder="Enter first name">
                    </div>

                    <div class="form-group">
                        <label>Last Name</label>
                        <input type="text" placeholder="Enter last name">
                    </div>

                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" placeholder="Enter email">
                    </div>

                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" placeholder="Enter phone number">
                    </div>

                    <div class="form-group">
                        <label>Date of Birth</label>
                        <input type="date">
                    </div>

                    <div class="form-group">
                        <label>Gender</label>
                        <select>
                            <option>Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Height (m)</label>
                        <input type="number" step="0.01" placeholder="1.75">
                    </div>

                    <div class="form-group">
                        <label>Weight (kg)</label>
                        <input type="number" step="0.1" placeholder="70">
                    </div>

                    <div class="form-group">
                        <label>Emergency Contact Name</label>
                        <input type="text" placeholder="Emergency contact">
                    </div>

                    <div class="form-group">
                        <label>Emergency Contact Number</label>
                        <input type="tel" placeholder="Contact number">
                    </div>

                    <div class="form-group full-width">
                        <label>Address</label>
                        <textarea rows="3" placeholder="Enter full address"></textarea>
                    </div>

                    <div class="form-group">
                        <label>Fitness Goal</label>
                        <select>
                            <option>Select Goal</option>
                            <option>Weight Loss</option>
                            <option>Muscle Gain</option>
                            <option>General Fitness</option>
                            <option>Strength Training</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Membership Plan</label>
                        <select>
                            <option>Select Plan</option>
                            <option>Monthly</option>
                            <option>Quarterly</option>
                            <option>Yearly</option>
                        </select>
                    </div>

                    <div class="form-group full-width">
                        <label>Medical Notes (Optional)</label>
                        <textarea rows="3" placeholder="Any medical conditions or notes"></textarea>
                    </div>

                </div>

                <div class="button-section">
                    <button type="submit">Register Member</button>
                </div>
            </form>
        </div>
    </div>
    </body>
</html>